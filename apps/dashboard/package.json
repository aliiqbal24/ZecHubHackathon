{
  "name": "@agentzcash/dashboard",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "files": [
    ".next/standalone/apps/dashboard",
    ".next/static",
    "public",
    "scripts",
    "package.json"
  ],
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "postbuild": "node scripts/prepare-standalone.mjs",
    "start": "node -e \"process.env.HOSTNAME=process.env.HOSTNAME||'127.0.0.1'; import('./.next/standalone/apps/dashboard/server.js')\""
  },
  "dependencies": {
    "@agentzcash/core": "0.2.0",
    "lucide-react": "^0.562.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
