{
  "name": "zecguard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run build -w @zecguard/core && concurrently -k -n DASH,MCP,VENDOR -c cyan,magenta,green \"npm run dev -w @zecguard/dashboard\" \"npm run dev -w @zecguard/mcp-server\" \"npm run dev -w @zecguard/demo-vendor\"",
    "dev:dashboard": "npm run dev -w @zecguard/dashboard",
    "dev:mcp": "npm run dev -w @zecguard/mcp-server",
    "dev:vendor": "npm run dev -w @zecguard/demo-vendor",
    "mcp:stdio": "npm run stdio -w @zecguard/mcp-server",
    "build": "npm run build -w @zecguard/core && npm run build -w @zecguard/demo-vendor && npm run build -w @zecguard/mcp-server && npm run build -w @zecguard/dashboard",
    "demo:reset": "node scripts/reset-demo-state.mjs",
    "demo:verify": "node scripts/verify-demo.mjs",
    "demo:agent-p2p": "node scripts/demo-agent-p2p.mjs",
    "demo:web-purchase": "node scripts/demo-web-purchase.mjs",
    "demo:coinsbee": "node scripts/demo-coinsbee.mjs",
    "test": "vitest run --exclude \"**/dist/**\"",
    "typecheck": "tsc -b packages/core apps/demo-vendor apps/mcp-server --pretty false"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "puppeteer-core": "^25.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
